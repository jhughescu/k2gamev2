<div class="modal-photo-header modal-event">
    <img src="assets/icons/Icons_Camera.png"  alt="" aria-hidden="true"/>
</div>
<!-- Modal body -->
<div class="modal-body center">

    <div class="selfie-photo">
        <img class="selfie-photo-background" src="assets/selfies/SelfieImages_Selfie-BG.png"  alt="" aria-hidden="true"/>
        <div class='selfie-climber'>
        <img class="sNOelfie-climber" src="assets/profiles/profileimages_{{filename}}.png"  alt="" aria-hidden="true"/>
        </div>
    </div>
    <p>{{name}} has sent you a selfie on their climb!</p>
    {{#if hasMessage}}
        <br><p>"{{message}}"</p>
    {{/if}}

</div>
