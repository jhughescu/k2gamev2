<h2>Session Summary</h2>
<div id='closer'><span>X</span></div>
<table>
{{#each session}}
<tr>
    <td>{{@key}}</td><td>{{this}}</td>
</tr>
{{/each}}
</table>
climbers:
<table>

<th>name</th><th>status</th><th>delays</th><th>total delay</th>
{{#each climbers}}
<tr>
    <td>{{name}}</td><td>{{status}}{{#if finished}} ({{finishTimeDisplay}}){{/if}}</td><td>{{allDelaysDisplay}}</td><td>{{totalDelays}}</td>
</tr>
{{/each}}
</table>
{{#if session.completionTime}}
<div class="completionTimePanel" style="margin: 20px 0; padding: 10px; border: 1px solid #ccc; background: #f8f8f8;">
    <h3>Completion Time</h3>
    <div style="font-size: 1.5em; font-weight: bold;">
        {{session.completionTimeDisplay}}
    </div>
</div>
{{/if}}
<table>
{{#each answers}}
<tr><td>{{@key}}) {{this}}</td></tr>
{{/each}}
</table>
<div class='sessionButton' id='download'>Download session data</div>
<div class='sessionButton' id='delete'>DELETE THIS SESSION</div>
